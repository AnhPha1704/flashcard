<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="400dp"
    android:height="400dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Labyrinth Paths (Isometric Style) -->
    <!-- Các khối mê cung 3D mô phỏng theo mẫu bạn cung cấp -->
    
    <!-- Top Surfaces (Mặt trên của các khối) -->
    <path
        android:pathData="M10,20 L30,10 L50,20 L30,30 Z M40,40 L60,30 L80,40 L60,50 Z M10,60 L30,50 L50,60 L30,70 Z M70,70 L90,60 L110,70 L90,80 Z"
        android:fillColor="#192C5B"
        android:alpha="0.08" />
        
    <!-- Side Faces - Left (Mặt bên trái - Bóng đổ nhẹ) -->
    <path
        android:pathData="M10,20 L10,35 L30,45 L30,30 Z M40,40 L40,55 L60,65 L60,50 Z M10,60 L10,75 L30,85 L30,70 Z"
        android:fillColor="#192C5B"
        android:alpha="0.12" />
        
    <!-- Side Faces - Right (Mặt bên phải - Bóng đổ đậm hơn) -->
    <path
        android:pathData="M30,30 L30,45 L50,35 L50,20 Z M60,50 L60,65 L80,55 L80,40 Z M30,70 L30,85 L50,75 L50,60 Z"
        android:fillColor="#192C5B"
        android:alpha="0.18" />

    <!-- Continuous Maze Lines (Các đường dẫn kết nối) -->
    <path
        android:pathData="M0,20 L20,10 L40,20 M60,10 L80,20 L100,10 M0,50 L20,40 L40,50 L60,40 L80,50 L100,40 M0,80 L20,70 L40,80 L60,70 L80,80 L100,70"
        android:strokeWidth="0.8"
        android:strokeColor="#192C5B"
        android:alpha="0.1" />

    <path
        android:pathData="M20,10 L20,30 M50,20 L50,40 M80,10 L80,30 M20,40 L20,60 M50,50 L50,70 M80,40 L80,60 M20,70 L20,90 M50,80 L50,100 M80,70 L80,90"
        android:strokeWidth="0.8"
        android:strokeColor="#192C5B"
        android:alpha="0.1" />

    <!-- Isometric Grid Accents -->
    <path
        android:pathData="M0,0 L100,50 M0,50 L100,100 M0,10 L100,60 M0,60 L100,110"
        android:strokeWidth="0.3"
        android:strokeColor="#192C5B"
        android:alpha="0.05" />
    <path
        android:pathData="M100,0 L0,50 M100,50 L0,100 M100,10 L0,60 M100,60 L0,110"
        android:strokeWidth="0.3"
        android:strokeColor="#192C5B"
        android:alpha="0.05" />

</vector>
